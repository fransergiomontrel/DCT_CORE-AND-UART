--synthesis_resources = lut 64 
SUBDESIGN add_sub_pvi
( 
	add_sub	:	input;
	dataa[31..0]	:	input;
	datab[31..0]	:	input;
	result[31..0]	:	output;
) 
VARIABLE
	result_int[32..0]	:	WIRE;
BEGIN 
	result_int[] = (dataa[], !add_sub) + (!add_sub $ datab[], !add_sub);
	result[] = result_int[32..1];
END;
--VALID FILE
